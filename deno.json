{
  "name": "@bounded-systems/baobab",
  "version": "0.1.0",
  "license": "MIT",
  "exports": "./src/mod.ts",
  "imports": {
    "@bounded-systems/lone": "jsr:@bounded-systems/lone@^0.6.0",
    "linkedom": "npm:linkedom@0.15.3",
    "@std/encoding": "jsr:@std/encoding@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "publish": {
    "exclude": [
      "spike",
      "tests",
      "docs",
      ".github",
      "deno.lock",
      "**/*.att.json"
    ]
  },
  "tasks": {
    "test": "deno test --allow-net --allow-read --fail-fast tests",
    "fmt": "deno fmt src tests",
    "lint": "deno lint src tests",
    "check": "deno check src tests",
    "ci": "deno fmt --check src tests && deno lint src tests && deno check src tests && deno test --allow-net --allow-read --fail-fast tests",
    "spike": "deno run --allow-net --allow-read --allow-write=spike spike/component-sha.ts",
    "spike:pinning": "deno run --allow-net --allow-read --allow-write=spike spike/with-pinning.ts"
  }
}
